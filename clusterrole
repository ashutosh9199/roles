apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: pod-reader
rules:
- apiGroups: ["","apps"]
  resources: ["nodes", "namespaces", "pods", "services", "deployments", "replicasets", "configmaps", "secrets", "statefulsets", "daemonsets", "jobs", "cronjobs"]
  verbs: ["get", "list", "watch", "create", "delete", "update", "patch"]
